<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Description</key>
    <string>Synchronisiert das lokale Munki-Repo mit S3. Der Sync wird nur ausgeführt, wenn während des AutoPkg-Durchlaufs ein Paket neu importiert wurde (munki_repo_changed = True).</string>
    <key>Identifier</key>
    <string>com.github.emetriq.autopkg.munkis3sync</string>
    <key>Input</key>
    <dict>
        <key>S3_SYNC_SCRIPT_PATH</key>
        <string>/usr/local/bin/munki-s3-sync.sh</string>
    </dict>
    <key>MinimumVersion</key>
    <string>0.2.0</string>
    <key>Process</key>
    <array>
        <dict>
            <key>Processor</key>
            <string>MunkiS3SyncProcessor</string>
            <key>Arguments</key>
            <dict>
                <key>s3_sync_script</key>
                <string>%S3_SYNC_SCRIPT_PATH%</string>
            </dict>
        </dict>
    </array>
</dict>
</plist>
