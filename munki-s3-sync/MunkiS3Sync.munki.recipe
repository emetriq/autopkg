<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Description</key>
    <string>Sync Munki catalogs to S3 and trigger VM tests if any other recipe in the same autopkg run imported something.</string>
    <key>Identifier</key>
    <string>com.github.emetriq.autopkg.munkis3sync</string>
    <key>Input</key>
    <dict>
        <key>TEST_SCRIPT_PATH</key>
        <string>/usr/local/bin/test_packages.py</string>
    </dict>
    <key>MinimumVersion</key>
    <string>0.2.0</string>
    <key>Process</key>
    <array>
        <dict>
            <key>Processor</key>
            <string>MunkiS3SyncProcessor</string>
        </dict>
        <dict>
            <key>Processor</key>
            <string>MunkiTestVMProcessor</string>
            <key>Arguments</key>
            <dict>
                <key>test_script_path</key>
                <string>%TEST_SCRIPT_PATH%</string>
            </dict>
        </dict>
    </array>
</dict>
</plist>
