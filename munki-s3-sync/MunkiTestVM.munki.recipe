<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Description</key>
    <string>Triggert den Munki-Testlauf in der GhostVM. Standardmäßig wird der Test nur ausgeführt, wenn Änderungen am Repo erkannt wurden (munki_repo_changed). Über die Variable force_run kann dies erzwungen werden.</string>
    <key>Identifier</key>
    <string>com.github.emetriq.autopkg.munkitestvm</string>
    <key>Input</key>
    <dict>
        <key>TEST_SCRIPT_PATH</key>
        <string>/usr/local/bin/test_packages.py</string>
        <key>force_run</key>
        <false/>
    </dict>
    <key>MinimumVersion</key>
    <string>0.2.0</string>
    <key>Process</key>
    <array>
        <dict>
            <key>Processor</key>
            <string>MunkiTestVMProcessor</string>
            <key>Arguments</key>
            <dict>
                <key>test_script_path</key>
                <string>%TEST_SCRIPT_PATH%</string>
                <key>force_run</key>
                <string>%force_run%</string>
            </dict>
        </dict>
    </array>
</dict>
</plist>
